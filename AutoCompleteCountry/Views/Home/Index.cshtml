@{
    ViewData["Title"] = "Home Page";
}

@model CountryViewModel

<div class="text-center">
    <h1 class="display-4">Search country</h1>
</div>

<div>

    <form asp-controller="Home" asp-action="SearchedCountry" method="get">
        <input type="hidden" id="CountryId" name="countryId" />
        <input type="text" id="Title" placeholder="Search" class="form-control" name="body" />
        <button type="submit" class="btn btn-outline-info">Hledat</button>
    </form>
</div>

<div class="card p-3 w-50">
    <table class="table mb-0">
        <tbody>
            <tr>
                <th>Country</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Country code</th>
                <td>@Model.CountryCode</td>
            </tr>
            <tr>
                <th>Currency</th>
                <td>@Model.Currency</td>
            </tr>
        </tbody>
    </table>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <script>
        $(function () {
            $("#Title").autocomplete({
                minLength: 2,
                delay: 250,
                source: function (request, response) {
                    $.ajax({
                        url: '@Url.Action("Search", "Home")',
                        type: "GET",
                        dataType: "json",
                        data: { searchedCountry: request.term },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return {
                                    label: item.name,
                                    value: item.name,
                                    id: item.id
                                };
                            }));
                        }
                    });
                },
                select: function (event, ui) {
                    $("#Title").val(ui.item.label);
                    $("#CountryId").val(ui.item.id);

                    return false;
                }
            });
        });
    </script>
}